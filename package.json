{
  "name": "meinopoly",
  "version": "1.0.0",
  "description": "A Monopoly demo built with boardgame.io",
  "main": "index.html",
  "scripts": {
    "start": "parcel index.html --open",
    "build": "parcel build index.html",
    "test": "jest && npx playwright test",
    "test:unit": "jest",
    "test:e2e": "npx playwright test",
    "server": "node -r esm server.js",
    "sim": "node -r esm src/sim/cli.js",
    "create-mod": "node -r esm scripts/create-mod.js",
    "extract-facts": "node -r esm scripts/extract-facts.js",
    "gen-portraits": "node -r esm scripts/gen-portraits.js",
    "mcp": "node scripts/mcp-server.js"
  },
  "browserslist": "defaults and supports async-functions",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "boardgame.io": "0.45.0",
    "esm": "^3.2.25",
    "globe.gl": "^2.46.1",
    "koa-static": "^5.0.0",
    "pngjs": "^7.0.0",
    "three": "^0.184.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@playwright/test": "^1.58.2",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "parcel-bundler": "^1.6.1",
    "playwright": "^1.58.2"
  }
}
